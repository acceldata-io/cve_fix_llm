# Copy to repo-local .env (git-ignored). It is loaded automatically on startup;
# you can also export these in your shell or run: source .env

# Jira (OSV project) credentials
export CVE_JIRA_EMAIL="you@example.com"
export CVE_JIRA_API_TOKEN="your-atlassian-api-token"

# Optional: override the Jira base URL
# export CVE_JIRA_BASE_URL="https://your-org.atlassian.net"

# Anthropic API key for cve_agent.py
export ANTHROPIC_API_KEY="sk-ant-..."

# GitHub token for PR creation / repo API (classic or fine-grained PAT with
# 'repo' scope). If unset, the tools fall back to your git credential helper.
export GITHUB_TOKEN="ghp_...or_github_pat_..."

# --- Portable machine paths (macOS or any Linux host) -----------------------
# Component checkouts land under CVE_WORKDIR/<profile> (default ~/cve_fix_workdir).
# export CVE_WORKDIR="$HOME/cve_fix_workdir"
#
# JDKs — set these on the remote if auto-detect fails:
#   Linux examples: /usr/lib/jvm/java-1.8.0-openjdk , /usr/lib/jvm/java-11-openjdk
#   macOS Corretto: ~/Library/Java/JavaVirtualMachines/corretto-*/Contents/Home
# export CVE_JAVA_HOME_8="/usr/lib/jvm/java-1.8.0-openjdk"   # 3.2.3.* baseline
# export CVE_JAVA_HOME_11="/usr/lib/jvm/java-11-openjdk"      # 3.3.6.* baseline
#
# Release baseline (selects JDK 8 vs 11 automatically in profiles / --address):
# export CVE_RELEASE="3.3.6.4"    # → JDK 11
# export CVE_RELEASE="3.2.3.6"    # → JDK 8

# --- Hybrid model tiers (cve_agent.py) --------------------------------------
# The agent routes work by difficulty: a cheap model for bulk triage, a mid
# model for orchestration + normal fixes, and a top model for hard remediation.
# It starts on CVE_AGENT_TIER and auto-escalates (one-way) to the FIX tier when
# a build/compile fails or the model emits an [ESCALATE] marker.
# export CVE_MODEL_TRIAGE="claude-haiku-4-5"    # cheap bulk triage/extraction
# export CVE_MODEL_ORCH="claude-sonnet-5"       # orchestration + normal fixes (default start)
# export CVE_MODEL_FIX="claude-opus-4-8"        # hard fixes / escalation target
# export CVE_AGENT_TIER="orch"                  # start tier: triage|orch|fix
# export CVE_AGENT_AUTO_ESCALATE="1"            # 0 = never auto-escalate

# Single-model mode: setting CVE_AGENT_MODEL pins ALL tiers to one model.
# export CVE_AGENT_MODEL="claude-opus-4-8"

# Optional run controls
# export CVE_PROFILE="spark2"
# export CVE_DRY_RUN="1"

# --- --address defaults (cve_agent.py --address <component>) ----------------
# export CVE_ADDRESS_RELEASE="3.3.6.4"
# export CVE_ADDRESS_BRANCH="nightly/3.3.6.5-1"   # checkout / fix branch
# export CVE_ADDRESS_PR_BASE="nightly/3.3.6.5"    # PR target
# export CVE_ADDRESS_REVIEWERS="kravii,basapuram-kumar,shubhluck,prabhjyotsingh"
