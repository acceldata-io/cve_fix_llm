# Copy to a local, git-ignored location and fill in real values.
# Either export these as environment variables, or place EMAIL=/API_TOKEN=
# lines in ~/.config/cve_fix/jira.env (override path with CVE_JIRA_CRED_FILE).

# Jira (OSV project) credentials
export CVE_JIRA_EMAIL="you@example.com"
export CVE_JIRA_API_TOKEN="your-atlassian-api-token"

# Optional: override the Jira base URL
# export CVE_JIRA_BASE_URL="https://your-org.atlassian.net"

# Anthropic API key for cve_agent.py
export ANTHROPIC_API_KEY="sk-ant-..."

# Optional agent/model + run controls
# export CVE_AGENT_MODEL="claude-opus-4-8"
# export CVE_PROFILE="spark2"
# export CVE_DRY_RUN="1"
